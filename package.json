{
  "name": "aamva-pdf417-generator",
  "version": "1.0.0",
  "description": "Professional Grade AAMVA PDF417 generator for DL/ID standards.",
  "author": "Sean Vera",
  "license": "MIT",
  "main": "main.js",
  "homepage": "https://github.com/SeanPVera/aamva-pdf417-generator#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeanPVera/aamva-pdf417-generator.git"
  },
  "bugs": {
    "url": "https://github.com/SeanPVera/aamva-pdf417-generator/issues"
  },
  "keywords": [
    "aamva",
    "pdf417",
    "barcode",
    "drivers-license",
    "dl-id",
    "react",
    "typescript",
    "vite",
    "electron",
    "client-side",
    "offline"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "electron .",
    "dev": "vite",
    "easy": "npm install && npm run dev",
    "easy:mobile": "npm install && npm run dev:mobile",
    "dev:mobile": "vite --host 0.0.0.0 --port 3000",
    "build": "vite build",
    "serve": "vite preview",
    "preview:mobile": "vite preview --host 0.0.0.0 --port 4173",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "size": "size-limit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "changeset publish",
    "format": "prettier --write src/**/*.{ts,tsx,css,json}",
    "format:check": "prettier --check src/**/*.{ts,tsx,css,json}",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && cross-env ELECTRON_IS_DEV=1 electron .\"",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb --publish never",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "src/**/*.{css,json}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "bwip-js": "^4.8.0",
    "crypto-js": "^4.2.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-app": "^12.1.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.7",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.2",
    "vitest": "^4.1.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.seanvera.aamva.pdf417",
    "productName": "AAMVA PDF417 Generator",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "extraMetadata": {
      "version": "1.0.0"
    }
  }
}
